{
  "manifest_version": 3,
  "name": "Copy Selected Tab URLs",
  "version": "1.1",
  "description": "Copies the URLs of all selected tabs to the clipboard, one per line.",
  "permissions": [
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
